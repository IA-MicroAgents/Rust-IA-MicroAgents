[Unit]
Description=AI MicroAgents Orchestrator
After=network.target

[Service]
Type=simple
User=aimicroagents
WorkingDirectory=/opt/ai-microagents
EnvironmentFile=/opt/ai-microagents/.env
ExecStart=/opt/ai-microagents/ai-microagents run
Restart=always
RestartSec=3
LimitNOFILE=65536
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
