# Network / runtime
FERRUM_BIND_ADDR=127.0.0.1:8080
FERRUM_IDENTITY_PATH=./IDENTITY.md
FERRUM_SKILLS_DIR=./skills

# Postgres (required)
FERRUM_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/ferrum
FERRUM_POSTGRES_SCHEMA=public

# Redis (required)
FERRUM_REDIS_URL=redis://127.0.0.1:6379
FERRUM_CACHE_NAMESPACE=ferrum

# OpenRouter (required unless mock mode is enabled in code)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=20000

# Telegram (required channel)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BASE_URL=https://api.telegram.org

# Safety / operator controls
FERRUM_OUTBOUND_ENABLED=true
FERRUM_DRY_RUN=false
FERRUM_OUTBOUND_KILL_SWITCH=false
FERRUM_HTTP_SKILL_ALLOWLIST=api.openai.com,example.com

# Dashboard
FERRUM_ENABLE_DASHBOARD=true
FERRUM_DASHBOARD_BIND=127.0.0.1:8080
FERRUM_DASHBOARD_AUTH_TOKEN=
